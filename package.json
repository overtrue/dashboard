{
  "name": "dashboard",
  "version": "0.1.0",
  "description": "AI-ready open-source admin dashboard framework built with Next.js, Refine, Drizzle ORM, and shadcn/ui.",
  "type": "module",
  "license": "MIT",
  "packageManager": "pnpm@11.7.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "check": "pnpm test && pnpm lint && pnpm typecheck && pnpm build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "start": "next start",
    "lint": "eslint",
    "test": "node --import tsx --test tests/*.test.ts",
    "typecheck": "tsc --noEmit",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx db/example/seed.ts"
  },
  "dependencies": {
    "@microlink/react-json-view": "^1.31.20",
    "@refinedev/core": "^5.0.12",
    "@refinedev/nextjs-router": "^7.0.5",
    "@refinedev/react-table": "^6.0.1",
    "@remixicon/react": "^4.9.0",
    "@tanstack/react-query": "^5.100.9",
    "@tanstack/react-table": "^8.21.3",
    "better-sqlite3": "^12.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.6",
    "refine-sqlx": "0.10.2",
    "shadcn": "^4.7.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.1.7",
    "postcss": "^8.5.14",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.4",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.20.0",
    "typescript": "^5.9.3"
  }
}
